// vesyla_template_start package_head
package {{name}}_{{fingerprint}}_pkg;
// vesyla_template_end package_head

  // vesyla_template_start package_macro
  {% include "package.j2" %}
  // vesyla_template_end package_macro

  import agu_rtr_pkg::*;

  parameter DEPTH = 64;
  parameter WIDTH = 256;
  parameter int NUM_AGUS = 2;

  // AGU RTR params
  parameter int ADDRESS_WIDTH = IO_ADDR_WIDTH;
  // Widths must be twice the isa.json rep field widths (base + repx half).
  // isa_refactor sets io rep iter/step/delay to 7 bits each.
  parameter int REP_ITER_WIDTH = 7 * 2; // REP + REPX
  parameter int REP_DELAY_WIDTH = 7 * 2; // REP + REPX
  parameter int REP_STEP_WIDTH = 7 * 2; // REP + REPX
  parameter int TRANS_DELAY_WIDTH = 23;
  // NUMBER_OR / NUMBER_MT / NUMBER_IR come from this resource's arch.json
  // custom_properties (emitted by package.j2 above); defaults live there.
  parameter int INCLUDE_IR_STATES = 1;
  parameter int INCLUDE_MT_STATES = 1;
  parameter int INCLUDE_OR_STATES = 1;

  {% include "agu_config.j2" %}

endpackage

