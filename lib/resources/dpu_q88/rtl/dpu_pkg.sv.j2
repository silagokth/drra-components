// vesyla_template_start package_head
package {{name}}_{{fingerprint}}_pkg;
// vesyla_template_end package_head

  // vesyla_template_start package_macro
  {% include "package.j2" %}
  // vesyla_template_end package_macro

  import agu_rtr_pkg::*;

  parameter int FSM_MAX_STATES = 4;
  parameter int FSM_DELAY_WIDTH = 3;
  parameter int DPU_MODE_WIDTH = 6;
  parameter int DPU_IMMEDIATE_WIDTH = 8;
  parameter int OPCODE_WIDTH = 4;
  parameter int BITWIDTH = 16;
  parameter int ACC_BITWIDTH = 32;
  parameter int Q88_FRAC_BITS = 8;
  localparam logic signed [ACC_BITWIDTH-1:0] Q88_MAX_16 = (ACC_BITWIDTH'(1) <<< (BITWIDTH - 1)) - 1;
  localparam logic signed [ACC_BITWIDTH-1:0] Q88_MIN_16 = -(ACC_BITWIDTH'(1) <<< (BITWIDTH - 1));

  function automatic logic signed [BITWIDTH-1:0] sat16_q88(
      input logic signed [ACC_BITWIDTH-1:0] value
  );
    if (value > Q88_MAX_16) begin
      sat16_q88 = Q88_MAX_16[BITWIDTH-1:0];
    end else if (value < Q88_MIN_16) begin
      sat16_q88 = Q88_MIN_16[BITWIDTH-1:0];
    end else begin
      sat16_q88 = value[BITWIDTH-1:0];
    end
  endfunction

  parameter int INSTRUCTION_PAYLOAD_WIDTH = 27;
  parameter int OPCODE_H = 26;
  parameter int OPCODE_L = 24;

  // AGU RTR params
  parameter int NUM_AGUS = 2;
  parameter int AGU_DPU_ADDR_WIDTH = $clog2(FSM_MAX_STATES);
  parameter int AGU_RST_ADDR_WIDTH = 1;
  parameter int ADDRESS_WIDTH = (AGU_DPU_ADDR_WIDTH > AGU_RST_ADDR_WIDTH) ? AGU_DPU_ADDR_WIDTH : AGU_RST_ADDR_WIDTH;
  // parameter int REP_OPTION_WIDTH = $clog2(FSM_MAX_STATES);
  parameter int REP_LEVEL_WIDTH = 3;
  parameter int REP_DELAY_WIDTH = 6 * 2; // REP + REPX
  parameter int REP_ITER_WIDTH = 7 * 2; // REP + REPX
  parameter int REP_STEP_WIDTH = 6 * 2; // REP + REPX
  parameter int TRANS_OPTION_WIDTH = 2;
  parameter int TRANS_DELAY_WIDTH = 22;
  parameter int NUMBER_OR = 4;
  parameter int NUMBER_MT = 3;
  parameter int NUMBER_IR = 4;

  typedef agu_config_class#(
    .NUMBER_IR         (NUMBER_IR),
    .NUMBER_MT         (NUMBER_MT),
    .NUMBER_OR         (NUMBER_OR),
    .REP_DELAY_WIDTH   (REP_DELAY_WIDTH),
    .REP_ITER_WIDTH    (REP_ITER_WIDTH),
    .REP_STEP_WIDTH    (REP_STEP_WIDTH),
    .TRANS_DELAY_WIDTH (TRANS_DELAY_WIDTH)
  )::agu_config_t agu_config_t;
endpackage
