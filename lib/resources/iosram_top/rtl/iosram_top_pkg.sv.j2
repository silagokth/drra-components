// vesyla_template_start package_head
package {{name}}_{{fingerprint}}_pkg;
// vesyla_template_end package_head

  // vesyla_template_start package_macro
  {% include "package.j2" %}
  // vesyla_template_end package_macro

  import agu_rtr_pkg::*;

  parameter int DEPTH = 64;
  parameter int WIDTH = 256;
  parameter int NUM_AGUS = 6;

  // AGU RTR params
  parameter int ADDRESS_WIDTH = (IO_ADDR_WIDTH > SRAM_ADDR_WIDTH) ? IO_ADDR_WIDTH : SRAM_ADDR_WIDTH;
  parameter int REP_ITER_WIDTH = 8 * 2; // REP + REPX
  parameter int REP_DELAY_WIDTH = 7 * 2; // REP + REPX
  parameter int REP_STEP_WIDTH = 7 * 2; // REP + REPX
  parameter int TRANS_LEVEL_WIDTH = 7;
  parameter int TRANS_DELAY_WIDTH = 7;
  parameter int NUMBER_OR = 4;
  parameter int NUMBER_MT = 3;
  parameter int NUMBER_IR = 4;
  parameter int INCLUDE_IR_STATES = 1;
  parameter int INCLUDE_MT_STATES = 1;
  parameter int INCLUDE_OR_STATES = 1;

  // Local AGU configuration struct mirroring agu_cfg_if's signal layout
  // so the controller can hold the registered configuration per AGU
  // before driving it onto the interface.
  typedef struct packed {
    logic [REP_DELAY_WIDTH-1:0] delay;
    logic [REP_ITER_WIDTH-1:0]  iter;
    logic [REP_STEP_WIDTH-1:0]  step;
    logic                       is_configured;
  } rep_config_t;

  typedef struct packed {
    logic [TRANS_DELAY_WIDTH-1:0] delay;
    logic                         is_configured;
  } trans_config_t;

  typedef struct packed {
    rep_config_t   [((NUMBER_OR > 0) ? NUMBER_OR : 1)-1:0] or_configs;
    trans_config_t [((NUMBER_MT > 0) ? NUMBER_MT : 1)-1:0] mt_configs;
    rep_config_t   [NUMBER_MT:0][NUMBER_IR-1:0]            ir_configs;
  } agu_config_t;
endpackage

