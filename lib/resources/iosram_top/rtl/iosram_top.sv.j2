// vesyla_template_start defines
`define {{name}} {{name}}_{{fingerprint}}
`define {{name}}_pkg {{name}}_{{fingerprint}}_pkg
// vesyla_template_end defines

// vesyla_template_start module_head
{% if not already_defined %}
module {{name}}_{{fingerprint}}
import {{name}}_{{fingerprint}}_pkg::*;
// vesyla_template_end module_head
(
    input  logic clk_0,
    output logic clk_out,
    input  logic rst_n,
    output  logic rst_n_out,

    input [$clog2(NUM_SLOTS)-1:0] resource_address,
    output [$clog2(NUM_SLOTS)-1:0] resource_address_out,
    input  logic [NUM_SLOTS-1:0] instr_en_resource,
    output  logic [NUM_SLOTS-1:0] instr_en_resource_out,
    input  logic [RESOURCE_INSTR_WIDTH-1:0] instr,
    output logic [RESOURCE_INSTR_WIDTH-1:0] instr_out,
    input  logic [NUM_SLOTS-1:0][FSM_PER_SLOT-1:0] activate,
    output logic [NUM_SLOTS-1:0][FSM_PER_SLOT-1:0] activate_out,

    input  logic [WORD_BITWIDTH-1:0] word_data_in_0,
    output logic [WORD_BITWIDTH-1:0] word_data_out_0,
    input  logic [BULK_BITWIDTH-1:0] bulk_data_in_0,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_0,
    input  logic [WORD_BITWIDTH-1:0] word_data_in_1,
    output logic [WORD_BITWIDTH-1:0] word_data_out_1,
    input  logic [BULK_BITWIDTH-1:0] bulk_data_in_1,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_1,
    input  logic [WORD_BITWIDTH-1:0] word_data_in_2,
    output logic [WORD_BITWIDTH-1:0] word_data_out_2,
    input  logic [BULK_BITWIDTH-1:0] bulk_data_in_2,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_2,
    input  logic [WORD_BITWIDTH-1:0] word_data_in_3,
    output logic [WORD_BITWIDTH-1:0] word_data_out_3,
    input  logic [BULK_BITWIDTH-1:0] bulk_data_in_3,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_3,
    output logic io_en_in,
    output logic [IO_ADDR_WIDTH-1:0] io_addr_in,
    input  logic [IO_DATA_WIDTH-1:0] io_data_in
);

    // Useless outputs:
    assign word_data_out_0 = 0;
    assign word_data_out_1 = 0;
    assign word_data_out_2 = 0;
    assign word_data_out_3 = 0;
    assign bulk_data_out_0 = 0;
    assign bulk_data_out_2 = 0;
    assign bulk_data_out_3 = 0;

    parameter RESOURCE_SLOTS = 4;
    logic instr_en_x [RESOURCE_SLOTS-1:0];
    logic [FSM_PER_SLOT-1:0] activate_x [RESOURCE_SLOTS-1:0];

    logic instr_en_0;
    logic instr_en_1;
    logic instr_en_2;
    logic instr_en_3;
    logic [FSM_PER_SLOT-1:0] activate_0;
    logic [FSM_PER_SLOT-1:0] activate_1;
    logic [FSM_PER_SLOT-1:0] activate_2;
    logic [FSM_PER_SLOT-1:0] activate_3;
    assign instr_en_0 = instr_en_x[0];
    assign instr_en_1 = instr_en_x[1];
    assign instr_en_2 = instr_en_x[2];
    assign instr_en_3 = instr_en_x[3];
    assign activate_0 = activate_x[0];
    assign activate_1 = activate_x[1];
    assign activate_2 = activate_x[2];
    assign activate_3 = activate_x[3];

    logic clk;
    clock_buffer #(1) clock_local_buffer (.clk(clk_0), .clk_out(clk));

    clock_buffer #(RESOURCE_SLOTS) clock_buffer (.clk(clk_0), .clk_out(clk_out));
    assign rst_n_out = rst_n;
    assign activate_out = activate;
    assign instr_en_resource_out = instr_en_resource;
    assign instr_out = instr;

    signal_selector #(
        .NUM_SLOTS(NUM_SLOTS),
        .RESOURCE_SLOTS(4),
        .FSM_PER_SLOT(FSM_PER_SLOT)
    ) signal_selector_0 (
        .resource_address(resource_address),
        .activate_resource(activate),
        .instr_valid_resource(instr_en_resource),
        .instr_valid(instr_en_x),
        .activate(activate_x),
        .resource_address_out(resource_address_out)
    );

    agu_config_t agu_configs [NUM_AGUS];
    logic [NUM_AGUS-1:0] agu_valid;
    logic [NUM_AGUS-1:0] agu_activate;
    assign agu_activate[0] = activate_0[0]; // slot 0 port 0
    assign agu_activate[1] = 1'b0; // NOTE: IO OUT disabled in iosram_top
    assign agu_activate[2] = activate_0[2]; // slot 0 port 2
    assign agu_activate[3] = 1'b0; // NOTE: IO OUT disabled in iosram_top
    assign agu_activate[4] = activate_1[2]; // slot 1 port 2
    assign agu_activate[5] = activate_1[3]; // slot 1 port 3

    logic [NUM_AGUS-1:0][ADDRESS_WIDTH-1:0] agu_address, agu_final_address;
    logic [NUM_AGUS-1:0][ADDRESS_WIDTH-1:0] agu_init_address;
    logic [NUM_AGUS-1:0] agu_done;
    genvar idx;
    generate
      for (idx = 0; idx < NUM_AGUS; idx++)
        assign agu_final_address[idx] = agu_address[idx] + agu_init_address[idx];
    endgenerate

    logic [INSTR_PAYLOAD_BITWIDTH-1:0] instruction_payload;
    logic [$clog2(3)-1:0] instruction_slot;
    logic instruction_valid;
    always_comb begin
      if (!rst_n) begin
        instruction_payload = '0;
        instruction_slot = '0;
        instruction_valid = 1'b0;
      end else begin
        if (instr_en_0) begin
          instruction_payload = instr[INSTR_PAYLOAD_BITWIDTH-1:0];
          instruction_slot = 0;
          instruction_valid = 1'b1;
        end else if (instr_en_1) begin
          instruction_payload = instr[INSTR_PAYLOAD_BITWIDTH-1:0];
          instruction_slot = 1;
          instruction_valid = 1'b1;
        end else begin
          instruction_payload = '0;
          instruction_slot = '0;
          instruction_valid = 1'b0;
        end
      end
  end

    logic dsu_valid;
    dsu_t dsu_instr;
    logic rep_valid;
    rep_t rep_instr;
    logic repx_valid;
    repx_t repx_instr;
    logic trans_valid;
    trans_t trans_instr;

    {{name}}_{{fingerprint}}_decoder decoder_inst (
      .clk(clk),
      .rst_n(rst_n),
      .instruction_valid(instruction_valid),
      .instruction_payload(instruction_payload),
      .dsu_valid(dsu_valid),
      .dsu_instr(dsu_instr),
      .rep_valid(rep_valid),
      .rep_instr(rep_instr),
      .repx_valid(repx_valid),
      .repx_instr(repx_instr),
      .trans_valid(trans_valid),
      .trans_instr(trans_instr)
    );

    {{name}}_{{fingerprint}}_controller controller_inst (
      .clk(clk),
      .rst_n(rst_n),

      .instruction_slot(instruction_slot),

      .dsu_valid(dsu_valid),
      .dsu_instr(dsu_instr),
      .rep_valid(rep_valid),
      .rep_instr(rep_instr),
      .repx_valid(repx_valid),
      .repx_instr(repx_instr),
      .trans_valid(trans_valid),
      .trans_instr(trans_instr),

      .agu_done(agu_done),
      .agu_configs(agu_configs),
      .init_address(agu_init_address)
    );

    genvar i;
    generate
      for (i = 0; i < NUM_AGUS; i++) begin : gen_agu
        // NOTE: IO OUT disabled in iosram_top
        if (i == 1 || i == 3) begin
          assign agu_valid[i] = 1'b0;
          assign agu_address[i] = '0;
          assign agu_done[i] = 1'b0;
        end else begin
          localparam int AGU_ADDR_WIDTH = (i == 0 || i == 1) ? IO_ADDR_WIDTH : SRAM_ADDR_WIDTH;
          agu_RTR #(
            .ADDRESS_WIDTH(AGU_ADDR_WIDTH),
            .REP_DELAY_WIDTH(REP_DELAY_WIDTH),
            .REP_ITER_WIDTH(REP_ITER_WIDTH),
            .REP_STEP_WIDTH(REP_STEP_WIDTH),
            .TRANS_DELAY_WIDTH(TRANS_DELAY_WIDTH),
            .NUMBER_OR(NUMBER_OR),
            .NUMBER_MT(NUMBER_MT),
            .NUMBER_IR(NUMBER_IR)
          ) agu_inst (
            .clk(clk),
            .rst_n(rst_n),
            .enable(1'b1),
            .activation(agu_activate[i]),
            .agu_config(agu_configs[i]),
            .addr_valid(agu_valid[i]),
            .addr(agu_address[i]),
            .done(agu_done[i])
          );
        end
      end
    endgenerate

    // merge the IO writing and normal writing to SRAM, IO has higher priority.
    // merge the writing and reading, writing has higher priority.
    logic [SRAM_ADDR_WIDTH-1:0] sram_in_addr;
    logic sram_in_en;
    logic [BULK_BITWIDTH-1:0] sram_in_data;
    logic [SRAM_ADDR_WIDTH-1:0] sram_out_addr;
    logic sram_out_en;
    logic [BULK_BITWIDTH-1:0] sram_out_data;
    logic [SRAM_ADDR_WIDTH-1:0] sram_addr;
    logic sram_write_en;

    // input ports
    always_comb begin
        // SRAM IN (AGU 2 - SLOT 0 PORT 2)
        if (agu_valid[2]) begin
            sram_in_en = 1;
            sram_in_addr = agu_final_address[2];
            sram_in_data = io_data_in;
        end
        // BULK IN (AGU 4 - SLOT 1 PORT 2)
        else if (agu_valid[4]) begin
            sram_in_en = 1;
            sram_in_addr = agu_final_address[4];
            sram_in_data = bulk_data_in_1;
        end
        else begin
            sram_in_en = 0;
            sram_in_addr = 0;
            sram_in_data = 0;
        end
    end

    // output ports
    always_comb begin
        // SRAM OUT (AGU 3 - SLOT 0 PORT 3)
        // if (agu_valid[3]) begin
        //     sram_out_en = 1;
        //     sram_out_addr = agu_final_address[3];
        //     io_data_out = sram_out_data;
        //     bulk_data_out_1 = 0;
        // end
        // else
        // NOTE: IO OUT disabled in iosram_top

        // BULK OUT (AGU 5 - SLOT 1 PORT 3)
        if (agu_valid[5]) begin
            sram_out_en = 1;
            sram_out_addr = agu_final_address[5];
            // io_data_out = 0;
            bulk_data_out_1 = sram_out_data;
        end
        else begin
            sram_out_en = 0;
            sram_out_addr = 0;
            // io_data_out = 0;
            bulk_data_out_1 = 0;
        end
    end

    // IO IN (AGU 0 - SLOT 0 PORT 0)
    assign io_en_in = agu_valid[0];
    assign io_addr_in = agu_final_address[0];

    // // IO OUT (AGU 1 - SLOT 0 PORT 1)
    // assign io_en_out = agu_valid[1];
    // assign io_addr_out = agu_final_address[1];
    // NOTE: IO OUT disabled in iosram_top

    sram #(
        .DEPTH(DEPTH),
        .WIDTH(WIDTH)
    ) sram_inst (
        .clk(clk),
        .enable_a_n(~sram_in_en),
        .enable_b_n(~sram_out_en),
        .write_enable_a_n(~sram_in_en),
        .write_enable_b_n(1'b1),
        .address_a(sram_in_addr),
        .address_b(sram_out_addr),
        .data_a(sram_in_data),
        .data_b('0),
        .q_b(sram_out_data)
    );
endmodule

// vesyla_template_start module_tail
{% endif %}
// vesyla_template_end module_tail
