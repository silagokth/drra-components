module twiddle_map
import {{fingerprint}}_pkg::*;
(
    input  logic [AGU_BITWIDTH-1:0] addr,
    input  logic [WORD_BITWIDTH-1:0] in_data,
    output logic [WORD_BITWIDTH-1:0] out_data
);

    logic sel0, sel1, sel2;
    logic [CTRL_BITWIDTH-1:0] circ_sec;
    logic [ROM_BITWIDTH-1:0] sec_addr;

    always_comb begin
        circ_sec = addr[CTRL_BITWIDTH + ROM_BITWIDTH-1 : ROM_BITWIDTH];
        sec_addr = addr[ROM_BITWIDTH-1 : 0];
        
        if ((circ_sec != 0) && (sec_addr == '0)) begin
            circ_sec = circ_sec - 1;
        end 

        case (circ_sec)
            0: begin
                sel0 = 0;
                sel1 = 0;
                sel2 = 0;
            end
            1: begin
                sel0 = 1;
                sel1 = 1;
                sel2 = 1;
            end
            2: begin
                sel0 = 1;
                sel1 = 1;
                sel2 = 0;
            end
            3: begin
                sel0 = 0;
                sel1 = 1;
                sel2 = 0;
            end
            4: begin
                sel0 = 0;
                sel1 = 1;
                sel2 = 1;
            end
            5: begin
                sel0 = 1;
                sel1 = 0;
                sel2 = 0;
            end
            default: begin
                sel0 = 0;
                sel1 = 0;
                sel2 = 0;
            end
        endcase
    end

    logic [WORD_BITWIDTH/2-1:0] in_data_r;
    logic [WORD_BITWIDTH/2-1:0] in_data_i;
    logic [WORD_BITWIDTH/2-1:0] temp_r;
    logic [WORD_BITWIDTH/2-1:0] temp_i;
    logic [WORD_BITWIDTH/2-1:0] out_data_r;
    logic [WORD_BITWIDTH/2-1:0] out_data_i;

    assign in_data_r = in_data[WORD_BITWIDTH-1:WORD_BITWIDTH/2];
    assign in_data_i = in_data[WORD_BITWIDTH/2-1:0];

    always_comb begin
        if (sel1 == 1) begin
            temp_r = ~in_data_r + 1;
        end else begin
            temp_r = in_data_r;
        end
        if (sel2 == 1) begin
            temp_i = ~in_data_i + 1;
        end else begin
            temp_i = in_data_i;
        end
        if (sel0 == 0) begin
            out_data_r = temp_r;
            out_data_i = temp_i;
        end else begin
            out_data_r = temp_i;
            out_data_i = temp_r;
        end
    end

    assign out_data = {out_data_r, out_data_i};
    
endmodule