// vesyla_template_start module_head
module dpu_decoder
import {{name}}_{{fingerprint}}_pkg::*;
// vesyla_template_end module_head
(
    input logic clk,
    input logic rst_n,

    input logic instruction_valid,
    input logic [INSTRUCTION_PAYLOAD_WIDTH-1:0] instruction,

    output logic conf_valid,
    output conf_t conf_instr,
    output logic evt_valid,
    output evt_t evt_instr,
    output logic rep_valid,
    output rep_t rep_instr,
    output logic trans_valid,
    output trans_t trans_instr
);
  // ─────────────────────────────────────────────────────────────────────────
  // Instruction Decoding
  // ─────────────────────────────────────────────────────────────────────────
  logic [OPCODE_WIDTH-1:0] opcode;
  assign opcode = instruction[OPCODE_H:OPCODE_L];

  assign conf_valid   = instruction_valid && (opcode == OPCODE_CONF);
  assign evt_valid   = instruction_valid && (opcode == OPCODE_EVT);
  assign rep_valid   = instruction_valid && (opcode == OPCODE_REP);
  assign trans_valid = instruction_valid && (opcode == OPCODE_TRANS);

  // ─────────────────────────────────────────────────────────────────────────
  // Instruction Unpacking
  // ─────────────────────────────────────────────────────────────────────────
  assign conf_instr   = conf_valid   ? unpack_conf(instruction)   :'0;
  assign evt_instr   = evt_valid   ? unpack_evt(instruction)   :'0;
  assign rep_instr   = rep_valid   ? unpack_rep(instruction)   :'0;
  assign trans_instr = trans_valid ? unpack_trans(instruction) :'0;

endmodule

