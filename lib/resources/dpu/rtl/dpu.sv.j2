// vesyla_template_start defines
`define {{name}} {{name}}_{{fingerprint}}
`define {{name}}_pkg {{name}}_{{fingerprint}}_pkg
// vesyla_template_end defines

// vesyla_template_start module_head
{% if not already_defined %}
module {{name}}_{{fingerprint}}
import {{name}}_{{fingerprint}}_pkg::*;
// vesyla_template_end module_head
(
    input logic clk_0,
    input logic rst_n_0,
    input logic instr_en_0,
    input logic [RESOURCE_INSTR_WIDTH-1:0] instr_0,
    input logic [3:0] activate_0,
    input logic [WORD_BITWIDTH-1:0] word_data_in_0,
    output logic [WORD_BITWIDTH-1:0] word_data_out_0,
    input logic [BULK_BITWIDTH-1:0] bulk_data_in_0,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_0,
    input logic clk_1,
    input logic rst_n_1,
    input logic instr_en_1,
    input logic [RESOURCE_INSTR_WIDTH-1:0] instr_1,
    input logic [3:0] activate_1,
    input logic [WORD_BITWIDTH-1:0] word_data_in_1,
    output logic [WORD_BITWIDTH-1:0] word_data_out_1,
    input logic [BULK_BITWIDTH-1:0] bulk_data_in_1,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_1
);

  // Useless output
  assign word_data_out_1 = 0;
  assign bulk_data_out_0 = 0;
  assign bulk_data_out_1 = 0;

  logic clk, rst_n;
  assign clk = clk_0;
  assign rst_n = rst_n_0;

  logic [NUM_AGUS-1:0] agu_activate;
  assign agu_activate[0] = activate_0[0];
  assign agu_activate[1] = activate_0[1];

  logic [INSTRUCTION_PAYLOAD_WIDTH-1:0] instruction;
  logic instruction_valid;
  assign instruction = instr_0;
  assign instruction_valid = instr_en_0;

  // Assign inputs
  logic [WORD_BITWIDTH-1:0] in0, in1, out0;
  assign in0 = word_data_in_0;
  assign in1 = word_data_in_1;

  logic [DPU_IMMEDIATE_WIDTH-1:0] immediate;
  logic [     DPU_MODE_WIDTH-1:0] dpu_mode;

  // Configuration signals from controller to AGU_RTR
  agu_config_t agu_configs [NUM_AGUS];

  logic [NUM_AGUS-1:0][ADDRESS_WIDTH-1:0] agu_address;
  logic [NUM_AGUS-1:0]                    agu_valid;
  logic [NUM_AGUS-1:0]                    agu_done;
  logic                                   reset_accumulator;
  assign reset_accumulator = agu_valid[1];

  genvar idx;
  generate
    for (idx = 0; idx < NUM_AGUS; idx++) begin : gen_agu
      localparam int AGU_ADDR_WIDTH = (idx == 0) ? AGU_DPU_ADDR_WIDTH : AGU_RST_ADDR_WIDTH;
      agu_rtr #(
          .ADDRESS_WIDTH(AGU_ADDR_WIDTH),
          .REP_DELAY_WIDTH(REP_DELAY_WIDTH),
          .REP_ITER_WIDTH(REP_ITER_WIDTH),
          .REP_STEP_WIDTH(REP_STEP_WIDTH),
          .TRANS_DELAY_WIDTH(TRANS_DELAY_WIDTH),
          .NUMBER_OR(NUMBER_OR),
          .NUMBER_MT(NUMBER_MT),
          .NUMBER_IR(NUMBER_IR)
      ) agu_rtr_inst (
          .clk(clk),
          .rst_n(rst_n),
          .enable(1'b1),
          .activation(agu_activate[idx]),
          .agu_config(agu_configs[idx]),
          .addr_valid(agu_valid[idx]),
          .addr(agu_address[idx]),
          .done(agu_done[idx])
      );
    end
  endgenerate

  logic dpu_valid;
  dpu_t dpu_instr;
  logic evt_valid;
  evt_t evt_instr;
  logic rep_valid;
  rep_t rep_instr;
  logic repx_valid;
  repx_t repx;
  logic trans_valid;
  trans_t trans_instr;

  dpu_decoder decoder_inst (
    .clk(clk),
    .rst_n(rst_n),

    .instruction_valid(instruction_valid),
    .instruction(instruction),

    .dpu_valid(dpu_valid),
    .dpu_instr(dpu_instr),
    .evt_valid(evt_valid),
    .evt_instr(evt_instr),
    .rep_valid(rep_valid),
    .rep_instr(rep_instr),
    .repx_valid(repx_valid),
    .repx_instr(repx_instr),
    .trans_valid(trans_valid),
    .trans_instr(trans_instr)
  );

  dpu_controller controller_inst (
    .clk  (clk),
    .rst_n(rst_n),

    .agu_done(agu_done),

    .evt_valid(evt_valid),
    .evt_instr(evt_instr),
    .rep_valid(rep_valid),
    .rep_instr(rep_instr),
    .repx_valid(repx_valid),
    .repx_instr(repx_instr),
    .trans_valid(trans_valid),
    .trans_instr(trans_instr),

    .agu_configs(agu_configs)
  );

  dpu_mode_selector mode_selector_inst (
    .clk(clk),
    .rst_n(rst_n),

    .dpu_valid(dpu_valid),
    .dpu_instr(dpu_instr),

    .dpu_agu_valid(agu_valid[0]),
    .dpu_agu_address(agu_address[0]),

    .dpu_mode(dpu_mode),
    .immediate(immediate)
  );

  // Calculation logic
  logic accumulator_valid;
  logic signed [BITWIDTH-1:0] acc0, acc0_next;
  logic signed [BITWIDTH-1:0] acc0_current;
  logic signed [BITWIDTH-1:0] adder_in0;
  logic signed [BITWIDTH-1:0] adder_in1;
  logic signed [BITWIDTH-1:0] adder_out;
  logic signed [BITWIDTH-1:0] mult_in0;
  logic signed [BITWIDTH-1:0] mult_in1;
  logic signed [BITWIDTH-1:0] mult_out;

  assign acc0_current = (reset_accumulator | agu_activate[1]) ? '0 : acc0;
  always_ff @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      acc0 <= '0;
      accumulator_valid <= 1'b0;
    end else begin
      acc0 <= acc0_next;
      accumulator_valid <= 1'b1;
    end
  end

  always_comb begin
    out0 = 0;
    adder_in0 = 0;
    adder_in1 = 0;
    mult_in0 = 0;
    mult_in1 = 0;
    acc0_next = 0;

    case (dpu_mode)
      DPU_MODE_ADD: begin
        adder_in0 = in0;
        adder_in1 = in1;
        out0 = adder_out;
      end
      DPU_MODE_MAC: begin
        mult_in0  = in0;
        mult_in1  = in1;
        adder_in0 = mult_out;
        if (accumulator_valid) begin
          adder_in1 = acc0_current;
        end else begin
          adder_in1 = '0;
        end
        acc0_next = adder_out;
        out0 = adder_out;
      end
      DPU_MODE_MULT: begin
        mult_in0 = in0;
        mult_in1 = in1;
        out0 = mult_out;
      end

      default: begin
        out0 = '0;
      end
    endcase
  end

  // in future we will use ChipWare blocks for pipelined and such
  {{name}}_{{fingerprint}}_adder adder_inst (
      .in1(adder_in0),
      .in2(adder_in1),
      .saturate(1'b1),
      .out(adder_out)
  );

  {{name}}_{{fingerprint}}_multiplier mult_inst (
      .in1(mult_in0),
      .in2(mult_in1),
      .saturate(1'b1),
      .out(mult_out)
  );

  // register output
  logic [WORD_BITWIDTH-1:0] out0_reg;
  always_ff @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      out0_reg <= 0;
    end else begin
      out0_reg <= out0;
    end
  end
  assign word_data_out_0 = out0_reg;

endmodule

// vesyla_template_start module_tail
{% endif %}
// vesyla_template_end module_tail

