// vesyla_template_start module_head
module {{name}}_{{fingerprint}}_multiplier
import {{name}}_{{fingerprint}}_pkg::*;
// vesyla_template_end module_head
(
    //! First operand
    input  logic signed [BITWIDTH-1:0] in1,
    //! Second operand
    input  logic signed [BITWIDTH-1:0] in2,
    //! Output product (truncated to BITWIDTH bits)
    output logic signed [BITWIDTH-1:0] out,
    //! Overflow flag
    output logic                       overflow,
    //! Underflow flag
    output logic                       underflow,
    //! Saturation enable
    input  logic                       saturate
);

  localparam int FRAC = FRACTIONAL_BITWIDTH;

  // In Q-product space, thresholds are shifted by FRAC bits
  localparam logic signed [BITWIDTH*2-1:0] MaxResult = ((1 << (BITWIDTH - 1)) - 1) <<< FRAC;
  localparam logic signed [BITWIDTH*2-1:0] MinResult = (-(1 << (BITWIDTH - 1))) <<< FRAC;

  logic signed [BITWIDTH*2-1:0] temp_mult;
  logic signed [BITWIDTH*2-1:0] temp_rounded;

  // Rounding
  generate
    if (FRAC > 0) begin : gen_round_half_away_from_zero

      logic sign_bit;
      logic round_up;

      always_comb begin
        sign_bit = temp_mult[BITWIDTH*2-1];

        // Round half away from zero. The output slice below is an arithmetic
        // shift (floor, toward -inf), so we only ever round UP (+1 in result
        // space = +2^FRAC in product space). Round up when the dropped fraction
        // exceeds half; for negatives an exact half must NOT round up so that
        // ties go away from zero (more negative), hence the extra lower-bits
        // test for the negative case.
        round_up = temp_mult[FRAC-1] & (sign_bit ? (|temp_mult[FRAC-2:0]) : 1'b1);
        temp_rounded = temp_mult + (round_up ? (1 <<< FRAC) : '0);
      end

    end else begin : gen_no_round

      always_comb temp_rounded = temp_mult;

    end
  endgenerate

  // Saturation + output
  always_comb begin : comb_saturation
    out       = '0;
    overflow  = 1'b0;
    underflow = 1'b0;
    temp_mult = in1 * in2;

    if (saturate) begin
      if (temp_rounded > MaxResult) begin
        out      = MaxResult[BITWIDTH-1+FRAC-:BITWIDTH];
        overflow = 1'b1;
      end else if (temp_rounded < MinResult) begin
        out       = MinResult[BITWIDTH-1+FRAC-:BITWIDTH];
        underflow = 1'b1;
      end else begin
        out = temp_rounded[BITWIDTH-1+FRAC-:BITWIDTH];
      end
    end else begin
      out = temp_rounded[BITWIDTH-1+FRAC-:BITWIDTH];
    end
  end

endmodule
