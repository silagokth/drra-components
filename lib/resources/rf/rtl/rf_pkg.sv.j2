// vesyla_template_start package_head
package {{name}}_{{fingerprint}}_pkg;
// vesyla_template_end package_head

  // vesyla_template_start package_macro
  {% include "package.j2" %}
  // vesyla_template_end package_macro

  parameter AGU_BITWIDTH = 16;

  // AGU RTR params
  parameter int ADDRESS_WIDTH = 6;
  parameter int REP_LEVEL_WIDTH = 4;
  parameter int REP_DELAY_WIDTH = 6;
  parameter int REP_ITER_WIDTH = 6;
  parameter int REP_STEP_WIDTH = 6;
  parameter int TRANS_LEVEL_WIDTH = 7;
  parameter int TRANS_DELAY_WIDTH = 7;
  parameter int NUMBER_OR = 4;
  parameter int NUMBER_MT = 3;
  parameter int NUMBER_IR = 4;
  parameter int INCLUDE_IR_STATES = 1;
  parameter int INCLUDE_MT_STATES = 1;
  parameter int INCLUDE_OR_STATES = 1;

  typedef struct {
    logic [REP_DELAY_WIDTH-1:0] delays [(NUMBER_MT+1)*NUMBER_IR];
    logic [REP_ITER_WIDTH-1:0]  iters  [(NUMBER_MT+1)*NUMBER_IR];
    logic [REP_STEP_WIDTH-1:0]  steps  [(NUMBER_MT+1)*NUMBER_IR];
    logic                       confs  [(NUMBER_MT+1)*NUMBER_IR];
  } agu_IR_config_t;

  typedef struct {
    logic [TRANS_DELAY_WIDTH-1:0] delays [NUMBER_MT];
    logic                         confs  [NUMBER_MT];
  } agu_MT_config_t;

  typedef struct {
    logic [REP_DELAY_WIDTH-1:0] delays [NUMBER_OR];
    logic [REP_ITER_WIDTH-1:0]  iters  [NUMBER_OR];
    logic [REP_STEP_WIDTH-1:0]  steps  [NUMBER_OR];
    logic                       confs  [NUMBER_OR];
  } agu_OR_config_t;

  typedef struct {
    agu_IR_config_t IR_configs;
    agu_MT_config_t MT_configs;
    agu_OR_config_t OR_configs;
  } agu_config_t;

endpackage

