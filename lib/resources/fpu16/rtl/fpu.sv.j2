`define {{name}} {{fingerprint}}
`define {{name}}_pkg {{fingerprint}}_pkg

{% if not already_defined %}
module {{fingerprint}}
import {{fingerprint}}_pkg::*;
(
    // Slot 0
    input  logic clk_0,
    input  logic rst_n_0,
    input  logic instr_en_0,
    input  logic [RESOURCE_INSTR_WIDTH-1:0] instr_0,
    input  logic [3:0] activate_0,
    input  logic [WORD_BITWIDTH-1:0] word_data_in_0,
    output logic [WORD_BITWIDTH-1:0] word_data_out_0,
    input  logic [BULK_BITWIDTH-1:0] bulk_data_in_0,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_0,
    // Slot 1
    input  logic clk_1,
    input  logic rst_n_1,
    input  logic instr_en_1,
    input  logic [RESOURCE_INSTR_WIDTH-1:0] instr_1,
    input  logic [3:0] activate_1,
    input  logic [WORD_BITWIDTH-1:0] word_data_in_1,
    output logic [WORD_BITWIDTH-1:0] word_data_out_1,
    input  logic [BULK_BITWIDTH-1:0] bulk_data_in_1,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_1,
    // Slot 2
    input  logic clk_2,
    input  logic rst_n_2,
    input  logic instr_en_2,
    input  logic [RESOURCE_INSTR_WIDTH-1:0] instr_2,
    input  logic [3:0] activate_2,
    input  logic [WORD_BITWIDTH-1:0] word_data_in_2,
    output logic [WORD_BITWIDTH-1:0] word_data_out_2,
    input  logic [BULK_BITWIDTH-1:0] bulk_data_in_2,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_2,
    // Slot 3
    input  logic clk_3,
    input  logic rst_n_3,
    input  logic instr_en_3,
    input  logic [RESOURCE_INSTR_WIDTH-1:0] instr_3,
    input  logic [3:0] activate_3,
    input  logic [WORD_BITWIDTH-1:0] word_data_in_3,
    output logic [WORD_BITWIDTH-1:0] word_data_out_3,
    input  logic [BULK_BITWIDTH-1:0] bulk_data_in_3,
    output logic [BULK_BITWIDTH-1:0] bulk_data_out_3
);

    logic clk, rst_n, instruction_valid, activate;
    logic [INSTRUCTION_PAYLOAD_WIDTH-1:0] instruction;
    
    assign clk = clk_0;
    assign rst_n = rst_n_0;
    assign instruction_valid = instr_en_0;
    assign activate = activate_0[0];
    assign instruction = instr_0;

    // useless output
    assign word_data_out_2 = 0;
    assign word_data_out_3 = 0;
    assign bulk_data_out_0 = 0;
    assign bulk_data_out_1 = 0;
    assign bulk_data_out_2 = 0;
    assign bulk_data_out_3 = 0;

    // register inputs
    logic [2*WORD_BITWIDTH-1:0] in0, in1, out0;        
    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            in0 <= 0;
            in1 <= 0;
        end else begin
            in0 <= {word_data_in_1, word_data_in_0};   
            in1 <= {word_data_in_3, word_data_in_2};
        end
    end

  logic [$clog2(FSM_MAX_STATES)-1:0][FPU_MODE_WIDTH-1:0] mode_memory;
  logic [$clog2(FSM_MAX_STATES)-1:0] fsm_state;
  logic [$clog2(FSM_MAX_STATES)-1:0] fsm_max_init_state;
  logic [FSM_MAX_STATES-2:0][FSM_DELAY_WIDTH-1:0] fsm_delays;
  logic [FPU_MODE_WIDTH-1:0] mode;
  logic [OPCODE_WIDTH-1:0] opcode;
  logic fpu_valid;
  logic fsm_valid;
  logic reset_accumulator;
  logic [2:0] src_format;

  fpu_t fpu;
  fsm_t fsm;

  fsm #(
      .FSM_MAX_STATES(FSM_MAX_STATES),
      .FSM_DELAY_WIDTH(FSM_DELAY_WIDTH)
  ) fsm_inst (
      .clk(clk),
      .rst_n(rst_n),
      .activate(|activate),
      .fsm_delays(fsm_delays),
      .max_init_state(fsm_max_init_state),
      .state(fsm_state)
  );

  assign opcode    = instruction[OPCODE_H:OPCODE_L];
  assign fpu_valid = instruction_valid && (opcode == OPCODE_FPU);
  assign fsm_valid = instruction_valid && (opcode == OPCODE_FSM);
  assign fpu = fpu_valid ? unpack_fpu(
          instruction[INSTRUCTION_PAYLOAD_WIDTH-1:0]
      ) :
      '{default: 0};
  assign fsm = fsm_valid ? unpack_fsm(
          instruction[INSTRUCTION_PAYLOAD_WIDTH-1:0]
      ) :
      '{default: 0};

  always_ff @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      mode_memory        <= '0;
      fsm_max_init_state <= '0;
      src_format         <= '0;
    end else begin
      if (fpu_valid) begin
        mode_memory[fpu._option] <= fpu._mode;
        fsm_max_init_state       <= fpu._option;
        src_format               <= fpu._format;
      end
    end
  end

  // TODO: we need to make the number of delays parametric somehow
  assign fsm_delays[0] = fsm._delay_0;
  assign fsm_delays[1] = fsm._delay_1;
  assign fsm_delays[2] = fsm._delay_2;

  assign mode = mode_memory[fsm_state];

  logic [BITWIDTH-1:0] acc0, acc0_next;
  logic [BITWIDTH-1:0] adder_in0;
  logic [BITWIDTH-1:0] adder_in1;
  logic [BITWIDTH-1:0] adder_out;
  logic [BITWIDTH-1:0] mult_in0;
  logic [BITWIDTH-1:0] mult_in1;
  logic [BITWIDTH-1:0] mult_out;

  always_ff @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      acc0 <= '0;
    end else begin
      if (reset_accumulator) begin
        acc0 <= '0;
      end else begin
        acc0 <= acc0_next;
      end
    end
  end

  always_comb begin
    out0 = 0;
    adder_in0 = 0;
    adder_in1 = 0;
    mult_in0 = 0;
    mult_in1 = 0;
    acc0_next = 0;

    case (mode)
      FPU_MODE_ADD: begin
        adder_in0 = in0;
        adder_in1 = in1;
        out0 = adder_out;
      end
      FPU_MODE_MAC: begin
        mult_in0 = in0;
        mult_in1 = in1;
        adder_in0 = mult_out;
        adder_in1 = acc0;
        acc0_next = adder_out;
        out0 = adder_out;
      end
      FPU_MODE_MUL: begin
        mult_in0 = in0;
        mult_in1 = in1;
        out0 = mult_out;
      end
    endcase
  end

  {{fingerprint}}_fp_adder fp_adder_inst (
      .src_format(src_format[1:0]),
      .op_a(adder_in0),
      .op_b(adder_in1),
      .result_o(adder_out)
  );

  {{fingerprint}}_fp_mul fp_mult_inst (
      .src_format(src_format[1:0]),
      .op_a(mult_in0),
      .op_b(mult_in1),
      .result_o(mult_out)
  );

  assign word_data_out_0 = out0[WORD_BITWIDTH-1:0];   // C_lo
  assign word_data_out_1 = out0[2*WORD_BITWIDTH-1:WORD_BITWIDTH];   // C_hi

endmodule

{% endif %}