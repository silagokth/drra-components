// vesyla_template_start module_head
module {{name}}_{{fingerprint}}_controller
import {{name}}_{{fingerprint}}_pkg::*;
// vesyla_template_end module_head
(
    input  logic clk,
    input  logic rst_n,

    // Instruction interface
    input  logic                              instruction_valid,
    input  logic [INSTR_PAYLOAD_BITWIDTH-1:0] instruction_payload,
    input  logic [NUM_AGUS-1:0]              agu_done,

    // SWB and ROUTE configuration signals
    output logic                          swb_conf_valid,
    output logic                          route_in_conf_valid,
    output logic                          route_out_conf_valid,
    output logic [$clog2(NUM_OPTIONS)-1:0] option_index,
    output logic [$clog2(NUM_SLOTS)-1:0]  swb_conf_link,
    output logic [$clog2(NUM_DIRS)-1:0]   route_in_conf_link,
    output logic [$clog2(NUM_SLOTS)-1:0]  route_out_conf_link,

    // Instruction valid signals
    output logic [NUM_OPTIONS-1:0] rep_valid_port,
    output logic [NUM_OPTIONS-1:0] trans_valid_port,

    // SWB and ROUTE configurations
    output swb_config_t           swb_configs      [NUM_OPTIONS],
    output route_receive_config_t route_in_configs  [NUM_OPTIONS],
    output route_send_config_t    route_out_configs [NUM_OPTIONS],

    // AGU configurations
    output agu_config_t        agu_configs      [NUM_AGUS],
    output logic [NUM_AGUS-1:0] agu_is_configured
);
  // ─────────────────────────────────────────────────────────────────────────
  // Instruction Decoding
  // ─────────────────────────────────────────────────────────────────────────
  logic [OPCODE_WIDTH-1:0] opcode;
  assign opcode = instruction_payload[OPCODE_H:OPCODE_L];

  logic evt_valid;
  logic swb_valid;
  logic route_valid;
  logic rep_valid;
  logic repx_valid;
  logic trans_valid;
  assign evt_valid   = instruction_valid && (opcode == OPCODE_EVT);
  assign swb_valid   = instruction_valid && (opcode == OPCODE_SWB);
  assign route_valid = instruction_valid && (opcode == OPCODE_ROUTE);
  assign rep_valid   = instruction_valid && (opcode == OPCODE_REP);
  assign repx_valid  = instruction_valid && (opcode == OPCODE_REPX);
  assign trans_valid = instruction_valid && (opcode == OPCODE_TRANS);

  // ─────────────────────────────────────────────────────────────────────────
  // Instruction Unpacking
  // ─────────────────────────────────────────────────────────────────────────
  evt_t   evt_instr;
  swb_t   swb_instr;
  route_t route_instr;
  rep_t   rep_instr;
  repx_t  repx_instr;
  trans_t trans_instr;
  assign evt_instr   = evt_valid   ? unpack_evt(instruction_payload)   : '{default: 0};
  assign swb_instr   = swb_valid   ? unpack_swb(instruction_payload)   : '{default: 0};
  assign route_instr = route_valid ? unpack_route(instruction_payload) : '{default: 0};
  assign rep_instr   = rep_valid   ? unpack_rep(instruction_payload)   : '{default: 0};
  assign repx_instr  = repx_valid  ? unpack_repx(instruction_payload)  : '{default: 0};
  assign trans_instr = trans_valid ? unpack_trans(instruction_payload) : '{default: 0};

  assign rep_valid_port   = rep_valid  ? (1 << rep_instr._port)  :
                            repx_valid ? (1 << repx_instr._port) : '0;
  assign trans_valid_port = trans_valid ? (1 << trans_instr._port) : '0;

  // ─────────────────────────────────────────────────────────────────────────
  // SWB and ROUTE Configuration
  // ─────────────────────────────────────────────────────────────────────────
  assign swb_conf_link       = swb_instr._source;
  assign route_in_conf_link  = route_instr._source;
  assign route_out_conf_link = route_instr._source;

  always_comb begin
    option_index = '0;

    swb_conf_valid       = 0;
    route_in_conf_valid  = 0;
    route_out_conf_valid = 0;

    swb_configs       = '{default: '{default: '0}};
    route_in_configs  = '{default: '{default: '0}};
    route_out_configs = '{default: '{default: '0}};

    if (swb_valid) begin
      swb_configs[swb_instr._option].slot_link[swb_instr._source] = swb_instr._target;
      swb_conf_valid = 1;
      option_index   = swb_instr._option;
    end else if (route_valid) begin
      if (route_instr._sr == ROUTE_SR_SEND) begin  // send
        route_out_configs[route_instr._option].send_links[route_instr._source] = route_instr._target[NUM_DIRS-1:0];
        route_out_conf_valid = 1;
        option_index         = route_instr._option;
      end else begin  // receive
        route_in_configs[route_instr._option].receive_links[route_instr._source] = route_instr._target;
        route_in_conf_valid = 1;
        option_index        = route_instr._option;
      end
    end
  end

  // ─────────────────────────────────────────────────────────────────────────
  // AGU Configuration
  // ─────────────────────────────────────────────────────────────────────────
  localparam int DELAY_HI = REP_DELAY_WIDTH / 2;
  localparam int ITER_HI  = REP_ITER_WIDTH  / 2;
  localparam int STEP_HI  = REP_STEP_WIDTH  / 2;

  agu_config_t agu_configs_reg   [NUM_AGUS];
  logic        use_or_reg        [NUM_AGUS];
  logic        or_configured_reg [NUM_AGUS];

  logic [$clog2(NUMBER_MT+1)-1:0] current_option [NUM_AGUS];
  logic [$clog2(NUM_LEVELS)-1:0]  current_level  [NUM_AGUS];
  logic [$clog2(NUMBER_MT+1)-1:0] current_trans  [NUM_AGUS];
  logic                           instr_port;

  assign instr_port =
    evt_valid   ? evt_instr._port   :
    rep_valid   ? rep_instr._port   :
    repx_valid  ? repx_instr._port  :
    trans_valid ? trans_instr._port : '0;

  always_ff @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      agu_configs_reg   <= '{default: '{default: '0}};
      use_or_reg        <= '{default: 1'b0};
      or_configured_reg <= '{default: 1'b0};
      current_option    <= '{default: '1};
      current_level     <= '{default: '0};
      current_trans     <= '{default: '0};
    end else if (|agu_done) begin
      for (int i = 0; i < NUM_AGUS; i++)
        if (agu_done[i]) begin
          agu_configs_reg[i]   <= '{default: '0};
          use_or_reg[i]        <= 1'b0;
          or_configured_reg[i] <= 1'b0;
          current_option[i]    <= '1;
          current_level[i]     <= '0;
          current_trans[i]     <= '0;
        end

    end else if (evt_valid) begin
      current_option[instr_port]                          <= current_option[instr_port] + 1;
      current_level[instr_port]                           <= '0;
      agu_configs_reg[instr_port].ir_configs[0][0].iter          <= 1;
      agu_configs_reg[instr_port].ir_configs[0][0].is_configured <= 1'b1;

    end else if (rep_valid || repx_valid) begin
      automatic logic [REP_OPTION_WIDTH-1:0]   opt      = current_option[instr_port];
      automatic logic [$clog2(NUM_LEVELS)-1:0] curr_lvl = current_level[instr_port];
      automatic logic [$clog2(NUM_LEVELS)-1:0] lvl      = rep_valid ? curr_lvl : (curr_lvl == '0 ? '0 : curr_lvl - 1);
      automatic logic [REP_DELAY_WIDTH/2-1:0]  dly      = rep_valid ? rep_instr._delay : repx_instr._delay;
      automatic logic [REP_ITER_WIDTH/2-1:0]   itr      = rep_valid ? rep_instr._iter  : repx_instr._iter;
      automatic logic [REP_STEP_WIDTH/2-1:0]   stp      = rep_valid ? rep_instr._step  : repx_instr._step;

      if (use_or_reg[instr_port]) begin
        if (rep_valid) begin // REP: configure lower half
          agu_configs_reg[instr_port].or_configs[lvl].delay[DELAY_HI-1:0] <= dly;
          agu_configs_reg[instr_port].or_configs[lvl].iter[ITER_HI-1:0]   <= itr;
          agu_configs_reg[instr_port].or_configs[lvl].step[STEP_HI-1:0]   <= stp;
        end else begin // REPX: configure upper half
          agu_configs_reg[instr_port].or_configs[lvl].delay[REP_DELAY_WIDTH-1:DELAY_HI] <= dly;
          agu_configs_reg[instr_port].or_configs[lvl].iter[REP_ITER_WIDTH-1:ITER_HI]    <= itr;
          agu_configs_reg[instr_port].or_configs[lvl].step[REP_STEP_WIDTH-1:STEP_HI]    <= stp;
        end
        agu_configs_reg[instr_port].or_configs[lvl].is_configured <= 1'b1;
        or_configured_reg[instr_port]                             <= 1'b1;
      end else begin
        if (rep_valid) begin // REP: configure lower half
          agu_configs_reg[instr_port].ir_configs[opt][lvl].delay[DELAY_HI-1:0] <= dly;
          agu_configs_reg[instr_port].ir_configs[opt][lvl].iter[ITER_HI-1:0]   <= itr;
          agu_configs_reg[instr_port].ir_configs[opt][lvl].step[STEP_HI-1:0]   <= stp;
        end else begin // REPX: configure upper half
          agu_configs_reg[instr_port].ir_configs[opt][lvl].delay[REP_DELAY_WIDTH-1:DELAY_HI] <= dly;
          agu_configs_reg[instr_port].ir_configs[opt][lvl].iter[REP_ITER_WIDTH-1:ITER_HI]    <= itr;
          agu_configs_reg[instr_port].ir_configs[opt][lvl].step[REP_STEP_WIDTH-1:STEP_HI]    <= stp;
        end
        agu_configs_reg[instr_port].ir_configs[opt][lvl].is_configured <= 1'b1;
      end

      if (rep_valid)
        current_level[instr_port] <= current_level[instr_port] + 1;

    end else if (trans_valid && !or_configured_reg[instr_port]) begin
      agu_configs_reg[instr_port].mt_configs[current_trans[instr_port]].delay         <= trans_instr._delay;
      agu_configs_reg[instr_port].mt_configs[current_trans[instr_port]].is_configured <= 1'b1;
      use_or_reg[instr_port]    <= 1'b1;
      current_level[instr_port] <= '0;
      current_trans[instr_port] <= current_trans[instr_port] + 1;
    end
  end

  assign agu_configs = agu_configs_reg;

  // ─────────────────────────────────────────────────────────────────────────
  // AGU Configured Check
  // ─────────────────────────────────────────────────────────────────────────
  always_comb begin
    agu_is_configured = '0;
    for (int i = 0; i < NUM_AGUS; i++) begin
      for (int l = 0; l <= NUMBER_MT; l++) begin
        if (agu_configs_reg[i].mt_configs[l].is_configured)
          agu_is_configured[i] = 1;
        for (int r = 0; r <= NUMBER_IR; r++) begin
          if (agu_configs_reg[i].ir_configs[l][r].is_configured)
            agu_is_configured[i] = 1;
        end
      end
    end
  end

endmodule
