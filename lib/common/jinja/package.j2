      logic [{{segment.bitwidth-1}}:0] _{{segment.name}};
      {% endif %}
      {% endfor %}
  } {{variant.name}}_t;

  function automatic {{variant.name}}_t unpack_{{variant.name}};
      input logic [{{payload_bitwidth - 1}}:0] instr;
      {{variant.name}}_t _{{variant.name}};
      {% set index=payload_bitwidth - 1 - instr.variant_opcode_bitwidth %}
      {% for segment in variant.segments %}
      {% if segment.bitwidth==1 %}
      _{{variant.name}}._{{segment.name}} = instr[{{index}}];
      {% else %}
      _{{variant.name}}._{{segment.name}}  = instr[{{index}}:{{index-segment.bitwidth+1}}];
      {% endif %}
      {% set index=index-segment.bitwidth %}
      {% endfor %}
      return _{{variant.name}};
  endfunction

  function automatic logic [{{ payload_bitwidth - 1 }}:0] pack_{{variant.name}};
      input {{variant.name}}_t _{{variant.name}};
      logic [{{ payload_bitwidth - 1 }}:0] instr;
      instr[{{ payload_bitwidth - 1 }}:{{ payload_bitwidth - instr.variant_opcode_bitwidth }}] = {{ variant.opcode }};
      {% set index=payload_bitwidth - 1 - instr.variant_opcode_bitwidth %}
