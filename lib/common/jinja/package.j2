  {% set payload_bitwidth = isa.format.instr_bitwidth - isa.format.instr_type_bitwidth - isa.format.instr_opcode_bitwidth - isa.format.instr_slot_bitwidth %}
  parameter int OPCODE_WIDTH = {{ isa.format.instr_opcode_bitwidth }};
  parameter int OPCODE_L = {{ payload_bitwidth }};
  parameter int OPCODE_H = {{ payload_bitwidth + isa.format.instr_opcode_bitwidth - 1 }};
  parameter int INSTRUCTION_PAYLOAD_WIDTH = {{ isa.format.instr_bitwidth - isa.format.instr_type_bitwidth - isa.format.instr_slot_bitwidth }};
  {% for instr in isa.instructions %}
  parameter int OPCODE_{{instr.name | upper }} = {{instr.opcode}};
  {% if instr.segments is defined and instr.segments|length > 0 %}
    {% for segment in instr.segments %}
      {% if segment.verbo_map is defined and segment.verbo_map | length > 0 %}
        {% for map in segment.verbo_map %}
  parameter int {{ instr.name | upper }}_{{ segment.name | upper }}_{{ map.val | replace(' ', '_') | replace('(', '') | replace(')', '') | upper }} = {{ map.key }};
        {% endfor %}
      {% endif %}
    {% endfor %}
  typedef struct packed {
      {% for segment in instr.segments %}
      {% if segment.bitwidth == 1 %}
      logic _{{segment.name}};
      {% else %}
      logic [{{segment.bitwidth-1}}:0] _{{segment.name}};
      {% endif %}
      {% endfor %}
  } {{instr.name}}_t;

  function automatic {{instr.name}}_t unpack_{{instr.name}};
      input logic [{{payload_bitwidth - 1}}:0] instr;
      {{instr.name}}_t _{{instr.name}};
      {% set index=payload_bitwidth -1 %}
      {% for segment in instr.segments %}
      {% if segment.bitwidth==1 %}
      _{{instr.name}}._{{segment.name}} = instr[{{index}}];
      {% else %}
      _{{instr.name}}._{{segment.name}}  = instr[{{index}}:{{index-segment.bitwidth+1}}];
      {% endif %}
      {% set index=index-segment.bitwidth %}
      {% endfor %}
      return _{{instr.name}};
  endfunction

  function automatic logic [{{ payload_bitwidth - 1 }}:0] pack_{{instr.name}};
      input {{instr.name}}_t _{{instr.name}};
      logic [{{ payload_bitwidth - 1 }}:0] instr;

      {% set index=payload_bitwidth -1 %}
      {% for segment in instr.segments %}
      {% if segment.bitwidth==1 %}
      instr[{{index}}] = _{{instr.name}}._{{segment.name}};
      {% else %}
      instr[{{index}}:{{index-segment.bitwidth+1}}] = _{{instr.name}}._{{segment.name}};
      {% endif %}
      {% set index=index-segment.bitwidth %}
      {% endfor %}
      return instr;
  endfunction
  {% endif %}
  {% if instr.variants is defined and instr.variants | length > 0 %}
