  parameter int OPCODE_{{ variant.name | upper }} = {{ variant.opcode }};
      {% for segment in variant.segments %}
        {% if segment.verbo_map is defined and segment.verbo_map | length > 0 %}
          {% for map in segment.verbo_map %}
  parameter int {{ variant.name | upper }}_{{ segment.name | upper }}_{{ map.val | replace(' ', '_') | replace('(', '') | replace(')', '') | upper }} = {{ map.key }};
          {% endfor %}
        {% endif %}
